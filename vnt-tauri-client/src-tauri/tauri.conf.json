{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VNT Core",
  "version": "0.1.5",
  "identifier": "top.wherewego.vnt.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "VNT Core",
        "width": 1280,
        "height": 792,
        "center": true,
        "minWidth": 390,
        "minHeight": 640,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon-512.png",
      "icons/icon.ico"
    ]
  }
}
